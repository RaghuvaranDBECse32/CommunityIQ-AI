{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build", "buildCommand": "npm run build" }
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "rewrites": [
    { "src": "/(.*)", "dest": "/" }
  ],
  "env": {
    "REACT_APP_API_URL": "https://communityiq-ai.onrender.com",
    "REACT_APP_MAPS_KEY": "YOUR_GOOGLE_MAPS_API_KEY"
  }
  "routes": [
    { "src": "/api/(.*)", "dest": "https://communityiq-ai.onrender.com/api/$1" }
  ]
}
